{
  "name": "dungeon-city-online",
  "version": "1.0.0",
  "description": "Cyberpunk text-based MMO web application",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "npm run build:api && npm run build:web",
    "build:api": "esbuild server/index.ts --bundle --outdir=dist --platform=node --target=node20 --external:@pg",
    "build:web": "vite build",
    "start": "node dist/index.js",
    "db:push": "drizzle-kit push",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.4.0",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.30.0",
    "express": "^5.0.0",
    "express-session": "^1.18.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.400.0",
    "pg": "^8.12.0",
    "pino": "^9.0.0",
    "pino-http": "^9.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.50.0",
    "react-query": "^3.39.0",
    "react-use": "^17.5.0",
    "wouter": "^3.3.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^4.17.0",
    "@types/express-session": "^1.17.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.0",
    "@tailwindcss/postcss": "^4.3.2",
    "concurrently": "^8.2.0",
    "drizzle-kit": "^0.25.0",
    "esbuild": "^0.21.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "zod": "^3.23.0"
  }
}
# PostgreSQL Database URL (from Neon, Supabase, or similar)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Session encryption secret (use a random 32+ character string)
SESSION_SECRET=your-random-secret-key-min-32-characters-change-in-production

# Environment
NODE_ENV=development

# Frontend URL (for CORS in production)
FRONTEND_URL=http://localhost:5173
